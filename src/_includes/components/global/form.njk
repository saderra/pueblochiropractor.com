  <form
        id="contact-form"
        class="max-w-[90%] mt-10"
        name="Pueblo Chiro Contact Form"
        method="POST"
        data-netlify="true"
        action="/contact/success"
      >

        <!-- Netlify hidden field -->
        <input type="hidden" name="form-name" value="Pueblo Chiro Contact Form" />

        <!-- Name -->
        <fieldset class="mb-6">
          <legend class="block text-sm font-semibold text-stone-700 mb-2">
            Name <span class="text-red-500">*</span>
          </legend>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="first-name" class="block text-xs text-stone-500 mb-1">First</label>
              <input
                type="text"
                id="first-name"
                name="first-name"
                required
                autocomplete="given-name"
                class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm text-stone-800 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition"
              />
            </div>
            <div>
              <label for="last-name" class="block text-xs text-stone-500 mb-1">Last</label>
              <input
                type="text"
                id="last-name"
                name="last-name"
                required
                autocomplete="family-name"
                class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm text-stone-800 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition"
              />
            </div>
          </div>
        </fieldset>

        <!-- Phone -->
        <div class="mb-6">
          <label for="phone" class="block text-sm font-semibold text-stone-700 mb-1">
            Phone <span class="text-red-500">*</span>
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            required
            autocomplete="tel"
            class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm text-stone-800 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition"
          />
        </div>

        <!-- Email -->
        <div class="mb-6">
          <label for="email" class="block text-sm font-semibold text-stone-700 mb-1">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            autocomplete="email"
            class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm text-stone-800 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition"
          />
        </div>

        <!-- Comments -->
        <div class="mb-8">
          <label for="comments" class="block text-sm font-semibold text-stone-700 mb-1">
            Comments <span class="text-red-500">*</span>
          </label>
          <p class="text-xs text-stone-400 mb-2">Please let us know what's on your mind. Have a question for us? Ask away.</p>
          <textarea
            id="comments"
            name="comments"
            required
            rows="5"
            class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm text-stone-800 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition resize-none"
          ></textarea>
        </div>

        <!-- Submit -->
        <button
          type="submit"
          class="w-full bg-teal-700 hover:bg-teal-800 text-white font-semibold text-sm uppercase tracking-widest py-3 rounded-full shadow transition-colors duration-200"
        >
          Send Message
        </button>

      </form>