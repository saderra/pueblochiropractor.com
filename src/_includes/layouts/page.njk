{% extends "layouts/base.njk" %}
{% block mainContent %}

        <div class="p-0 col-span-12 lg:col-span-8">
           <article class="max-w-full p-12">
            <div class="prose">
               <h1 class="text-3xl md:text-4xl pb-8 mb-8 font-normal">
                {% if contentTitle %}
                    {{ contentTitle }}
                {% else %}
                    {{ title }}
                {% endif %}
                </h1>
                {{ content | safe }}
                </div>
            </article>
        </div>

{% endblock %}


